@model LibraryApplication.Models.Book

<h2>Yeni Kitap Ekle</h2>

<form asp-action="Add" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Baslik" class="form-label"></label>
        <input asp-for="Baslik" class="form-control" />
        <span asp-validation-for="Baslik" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Yazar" class="form-label"></label>
        <input asp-for="Yazar" class="form-control" />
        <span asp-validation-for="Yazar" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Fiyat" class="form-label"></label>
        <input asp-for="Fiyat" class="form-control" />
        <span asp-validation-for="Fiyat" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Stok" class="form-label"></label>
        <input asp-for="Stok" class="form-control" />
        <span asp-validation-for="Stok" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
            <option value="">-- Kategori Seçiniz --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
