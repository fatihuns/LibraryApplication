@model IEnumerable<LibraryApplication.Models.Book>

<h2>Kitaplar</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    <a asp-action="Add" class="btn btn-primary">Yeni Kitap Ekle</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Başlık</th>
            <th>Yazar</th>
            <th class="text-end">Fiyat</th>
            <th class="text-end">Stok</th>
            <th>Aksiyon</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td class="text-end">@item.Price.ToString("0.00")</td>
                <td class="text-end">@item.Stock</td>
                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinizden emin misiniz?');">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
